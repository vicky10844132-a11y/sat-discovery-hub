# GS LinkOps AI environment example

APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

DATABASE_URL=postgresql://gs_linkops:gs_linkops@localhost:5432/gs_linkops

# Orbit engine
ORBIT_ENGINE_MODE=skyfield_sgp4
TLE_REFRESH_ENABLED=false
TLE_REFRESH_SOURCE=

# Transfer center
DEFAULT_TRANSFER_METHOD=SFTP
DEFAULT_RETENTION_HOURS=72
TEMP_STORAGE_PROVIDER=minio
TEMP_STORAGE_BUCKET=gs-linkops-temp

# Billing
DEFAULT_BILLING_TRIGGER="Transfer Completed + Operator / Manufacturer Confirmed"
DEFAULT_CURRENCY=USD
DEFAULT_SERVICE_FEE_USD=1000

# AI Copilot
AI_COPILOT_MODE=rules_first
LLM_PROVIDER=
LLM_API_KEY=

# Security
ENABLE_RBAC=true
ENABLE_AUDIT_LOGS=true
